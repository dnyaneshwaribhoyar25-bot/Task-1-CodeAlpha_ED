def main():
    print("\n" + "="*70)
    print("🚀 TASK 2: EXPLORATORY DATA ANALYSIS (EDA)")
    print("="*70)
    
    print("\nUse sample dataset? (y/n): ")
    use_sample = input().strip().lower()
    
    if use_sample == 'y':
        df = create_sample_dataset()
        print("\n✓ Using sample Amazon reviews dataset (15 reviews)")
    else:
        filepath = input("Enter CSV file path: ").strip()
        try:
            df = pd.read_csv(filepath)
            print(f"\n✓ Loaded dataset from {filepath}")
        except:
            print("\n✗ Error. Using sample dataset.")
            df = create_sample_dataset()
    
    print("\nMinimum rating to analyze (1-5): ")
    min_rating = int(input().strip())
    
    df_filtered = df[df['rating'] >= min_rating]
    print(f"\n✓ Filtered: {len(df_filtered)} reviews (rating >= {min_rating})")
    
    # EDA continues...
    print("\n" + "="*70)
    print("EDA RESULTS:")
    print("="*70)
    print(f"\nTotal rows: {df_filtered.shape[0]}")
    print(f"Total columns: {df_filtered.shape[1]}")
    print(f"\nRating Mean: {df_filtered['rating'].mean():.2f}")
    print(f"Rating Median: {df_filtered['rating'].median():.2f}")
    
    print("\n" + "="*70)
    print("✅ TASK 2 COMPLETE!")
    print("="*70)

if __name__ == "__main__":
    main()
